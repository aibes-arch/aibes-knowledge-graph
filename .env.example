# LLM (OpenAI-compatible, e.g. OpenAI / DeepSeek / vLLM / Ollama)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-key
LLM_MODEL=gpt-4o-mini

# Set to true to use built-in heuristic extractor for MVP demo without LLM
MOCK_LLM=false

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
